# SUDEASEG Dashboard - Variables de entorno
# Copiar a .env y completar valores

SUDEASEG_BASE_URL=https://www.sudeaseg.gob.ve
BCV_URL=https://www.bcv.org.ve
DOLAR_API_BASE=https://api.dolarapi.com

# Supabase (obtener en https://supabase.com/dashboard)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key

# Opcional: exigir login con Supabase Auth (true/false)
REQUIRE_AUTH=false

# ETL: depurar un año a la vez (dejar vacío o 0 = todos los años)
# ETL_TARGET_YEAR=2023
# ETL_DEBUG=true

# Retardos para scraping (segundos)
REQUEST_DELAY_MIN=1
REQUEST_DELAY_MAX=3
